    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content="Your agent forgets everything. ClawMem gives it memory that persists across sessions, stays inspectable, and brings back the right context before the next run." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://clawmem.ai/" />
    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
