---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'ClawMem - Memory for OpenClaw',
  description = 'ClawMem gives OpenClaw durable, searchable memory that survives resets, sessions, and time.'
} = Astro.props;
---

