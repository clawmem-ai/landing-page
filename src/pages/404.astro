<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>404 - Page Not Found | ClawMem</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://api.fontshare.com" />
    <link rel="preconnect" href="https://cdn.fontshare.com" crossorigin />
    <link href="https://api.fontshare.com/v2/css?f[]=general-sans@700,600,500&f[]=satoshi@400,500,700&display=swap" rel="stylesheet" />
    <style>
      :root { color-scheme: dark; --bg-deep: #080a14; --text-primary: #f0f4ff; --text-secondary: #8892b0; --coral-bright: #e0475a; }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: 'Satoshi', system-ui, sans-serif; background: var(--bg-deep); color: var(--text-primary); min-height: 100vh; display: flex; align-items: center; justify-content: center; }
      .container { text-align: center; padding: 2rem; }
      h1 { font-family: 'General Sans', system-ui, sans-serif; font-size: 4rem; color: var(--coral-bright); margin-bottom: 0.5rem; }
      p { color: var(--text-secondary); margin-bottom: 1.5rem; font-size: 1.1rem; }
      a { color: var(--coral-bright); text-decoration: none; border-bottom: 1px solid transparent; transition: border-color 0.2s; }
      a:hover { border-color: var(--coral-bright); }
    </style>
  </head>
  <body>
    <div class="container">
      <h1>404</h1>
      <p>Page not found.</p>
      <a href="/">Back to ClawMem</a>
    </div>
  </body>
</html>
