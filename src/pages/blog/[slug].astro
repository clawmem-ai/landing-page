---
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{post.data.title} - ClawMem Blog</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://api.fontshare.com" />
    <link rel="preconnect" href="https://cdn.fontshare.com" crossorigin />
    <link href="https://api.fontshare.com/v2/css?f[]=general-sans@700,600,500&f[]=satoshi@400,500,700&display=swap" rel="stylesheet" />
    <style>
      :root { color-scheme: dark; --bg-deep: #080a14; --text-primary: #f0f4ff; --text-secondary: #8892b0; --coral-bright: #e0475a; --cyan-bright: #2dd4b8; --bg-surface: #0c1020; --border-subtle: rgba(136, 146, 176, 0.12); }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: 'Satoshi', system-ui, sans-serif; background: var(--bg-deep); color: var(--text-primary); min-height: 100vh; }
      .container { max-width: 720px; margin: 0 auto; padding: 0 1.5rem; }
      .blog-nav { display: flex; gap: 1.5rem; padding: 1.5rem 0; }
      .blog-nav a { color: var(--text-secondary); text-decoration: none; transition: color 0.2s; }
      .blog-nav a:hover { color: var(--coral-bright); }
      article { padding-bottom: 4rem; }
      article h1 { font-family: 'General Sans', system-ui, sans-serif; font-size: 2.25rem; margin: 2rem 0 0.5rem; }
      article time { color: var(--text-secondary); font-size: 0.9rem; display: block; margin-bottom: 2rem; }
      article :global(h2) { font-family: 'General Sans', system-ui, sans-serif; font-size: 1.5rem; margin: 2rem 0 1rem; }
      article :global(p) { line-height: 1.7; margin-bottom: 1rem; color: var(--text-secondary); }
      article :global(a) { color: var(--coral-bright); }
      article :global(code) { background: var(--bg-surface); padding: 0.15em 0.4em; border-radius: 4px; font-size: 0.9em; }
      article :global(pre) { background: var(--bg-surface); padding: 1rem; border-radius: 0.5rem; overflow-x: auto; margin: 1rem 0; border: 1px solid var(--border-subtle); }
    </style>
  </head>
  <body>
    <div class="container">
      <nav class="blog-nav">
        <a href="/">Home</a>
        <a href="/blog/">&larr; Blog</a>
      </nav>
      <article>
        <h1>{post.data.title}</h1>
        <time datetime={post.data.date.toISOString()}>
          {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <Content />
      </article>
    </div>
  </body>
</html>
