---
import Landing from '../../layouts/Landing.astro';
import '../../styles/landing.css';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Landing title={`${post.data.title} - ClawMem Blog`} description={post.data.description}>
  <style>
    .post-container { max-width: 720px; margin: 0 auto; padding: 0 1.5rem; }
    article { padding: 3rem 0 4rem; }
    article h1 { font-family: var(--font-display); font-size: 2.25rem; color: var(--text-primary); margin: 0 0 1.25rem; text-align: center; }
    .author-wrap { text-align: center; }
    .author { display: inline-flex; align-items: center; gap: 0.625rem; margin-bottom: 2.5rem; }
    .author img { width: 36px; height: 36px; border-radius: 50%; object-fit: cover; flex-shrink: 0; display: block; }
    .author-info { display: inline-flex; flex-direction: column; text-align: left; }
    .author-name { font-weight: 600; font-size: 0.9rem; line-height: 1.3; color: var(--text-primary); }
    .author-date { font-size: 0.8rem; line-height: 1.3; color: var(--text-secondary); display: inline; margin: 0; }
    .post-date { color: var(--text-secondary); font-size: 0.9rem; display: block; margin-bottom: 2.5rem; text-align: center; }
    article :global(h2) { font-family: var(--font-display); font-size: 1.5rem; color: var(--text-primary); margin: 2.5rem 0 1rem; }
    article :global(h3) { font-family: var(--font-display); font-size: 1.2rem; color: var(--text-primary); margin: 2rem 0 0.75rem; }
    article :global(p) { line-height: 1.75; margin-bottom: 1rem; color: var(--text-secondary); }
    article :global(a) { color: var(--coral-bright); }
    article :global(strong) { color: var(--text-primary); }
    article :global(code) { background: var(--bg-surface); padding: 0.15em 0.4em; border-radius: 4px; font-size: 0.9em; }
    article :global(pre) { background: var(--bg-surface); padding: 1rem; border-radius: var(--radius); overflow-x: auto; margin: 1rem 0; border: 1px solid var(--border-subtle); }
    article :global(ul), article :global(ol) { padding-left: 1.5rem; margin-bottom: 1rem; color: var(--text-secondary); line-height: 1.75; }
    article :global(li) { margin-bottom: 0.25rem; }
    article :global(blockquote) { border-left: 3px solid var(--coral-bright); padding-left: 1rem; margin: 1.5rem 0; color: var(--text-secondary); font-style: italic; }
    article :global(hr) { border: none; border-top: 1px solid var(--border-subtle); margin: 2rem 0; }
    article :global(.comparison-table) { margin: 1.5rem 0 2rem; overflow-x: auto; border: 1px solid var(--border-subtle); border-radius: var(--radius); background: var(--surface-card); box-shadow: 0 16px 40px rgba(0, 0, 0, 0.12); }
    article :global(.comparison-table table) { width: 100%; min-width: 640px; border-collapse: collapse; margin: 0; }
    article :global(.comparison-table thead) { background: linear-gradient(135deg, rgba(255, 117, 90, 0.16), rgba(255, 173, 102, 0.12)); }
    article :global(.comparison-table th) { text-align: left; padding: 1rem 1.1rem; font-size: 0.82rem; letter-spacing: 0.04em; text-transform: uppercase; color: var(--text-primary); border-bottom: 1px solid var(--border-subtle); }
    article :global(.comparison-table td) { vertical-align: top; padding: 1rem 1.1rem; color: var(--text-secondary); border-bottom: 1px solid var(--border-subtle); line-height: 1.65; }
    article :global(.comparison-table tbody tr:last-child td) { border-bottom: none; }
    article :global(.comparison-table tbody tr:nth-child(even)) { background: rgba(255, 255, 255, 0.02); }
    article :global(.comparison-table strong) { color: var(--text-primary); }
    article :global(.full-comparison-table) { margin: 1.75rem 0 2.25rem; overflow-x: auto; border: 1px solid var(--border-subtle); border-radius: var(--radius); background: linear-gradient(180deg, rgba(255, 255, 255, 0.025), rgba(255, 255, 255, 0.01)); box-shadow: 0 18px 44px rgba(0, 0, 0, 0.12); }
    article :global(.full-comparison-table table) { width: 100%; min-width: 980px; border-collapse: separate; border-spacing: 0; margin: 0; }
    article :global(.full-comparison-table thead) { background: linear-gradient(135deg, rgba(255, 117, 90, 0.18), rgba(255, 173, 102, 0.14)); }
    article :global(.full-comparison-table th) { text-align: left; vertical-align: bottom; padding: 1rem 1rem 0.95rem; font-size: 0.78rem; letter-spacing: 0.05em; text-transform: uppercase; color: var(--text-primary); border-bottom: 1px solid var(--border-subtle); }
    article :global(.full-comparison-table td) { vertical-align: top; padding: 1rem; color: var(--text-secondary); line-height: 1.65; border-bottom: 1px solid var(--border-subtle); }
    article :global(.full-comparison-table tbody tr:last-child td) { border-bottom: none; }
    article :global(.full-comparison-table tbody tr:nth-child(even)) { background: rgba(255, 255, 255, 0.02); }
    article :global(.full-comparison-table td:first-child), article :global(.full-comparison-table th:first-child) { position: sticky; left: 0; z-index: 1; background: inherit; }
    article :global(.full-comparison-table td:first-child) { font-weight: 600; color: var(--text-primary); background: rgba(15, 20, 26, 0.92); }
    article :global(.full-comparison-table th:first-child) { z-index: 2; background: linear-gradient(135deg, rgba(255, 117, 90, 0.22), rgba(255, 173, 102, 0.18)); }
    article :global(.install-block) { margin: 1rem 0; }
    article :global(.install-block pre) { margin: 0; background: transparent; border: none; border-radius: 0; padding: 0; flex: 1; min-width: 0; }
    article :global(.install-command) { overflow-x: auto; justify-content: space-between; }
    article :global(.install-command code) { background: transparent; padding: 0; border-radius: 0; font-size: 0.875rem; }
  </style>

  <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
    <span class="theme-icon theme-icon-dark">&#9790;</span>
    <span class="theme-icon theme-icon-light">&#9728;</span>
  </button>

  <nav class="nav">
    <div class="container nav-inner">
      <a href="/" class="brand" aria-label="ClawMem home">
        <span class="brand-text">Claw</span><span class="brand-accent">Mem</span>
      </a>
      <div class="nav-right">
        <div class="nav-links">
          <a href="/">Home</a>
          <a href="/blog/">Blog</a>
          <a href="https://console.clawmem.ai/" target="_blank" rel="noreferrer">Console</a>
        </div>
      </div>
    </div>
  </nav>

  <div class="post-container">
    <article>
      <h1>{post.data.title}</h1>
      {post.data.author ? (
        <div class="author-wrap">
          <div class="author">
            {post.data.authorPhoto && <img src={post.data.authorPhoto} alt={post.data.author} />}
            <div class="author-info">
              <span class="author-name">{post.data.author}</span>
              <time class="author-date" datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
            </div>
          </div>
        </div>
      ) : (
        <time class="post-date" datetime={post.data.date.toISOString()}>
          {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
      )}
      <Content />
    </article>
  </div>

  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-nav">
        <a href="/">Home</a>
        <span class="footer-separator">&middot;</span>
        <a href="/blog/" data-i18n="nav.blog">Blog</a>
        <span class="footer-separator">&middot;</span>
        <a href="https://console.clawmem.ai/" target="_blank" rel="noreferrer" data-i18n="nav.console">Console</a>
      </div>
      <p class="copyright" data-i18n="footer.tagline">Structured memory for OpenClaw agents.</p>
      <p class="disclaimer" data-i18n="footer.license">Apache-2.0 License</p>
    </div>
  </footer>

  <script is:inline>
    document.querySelectorAll('article pre').forEach(function(pre) {
      var block = document.createElement('div');
      block.className = 'install-block';

      var head = document.createElement('div');
      head.className = 'install-block-head';
      for (var i = 0; i < 3; i++) {
        var dot = document.createElement('span');
        dot.className = 'code-dot';
        head.appendChild(dot);
      }
      block.appendChild(head);

      var cmd = document.createElement('div');
      cmd.className = 'install-command';

      var codeEl = pre.querySelector('code');
      var text = codeEl ? codeEl.textContent : pre.textContent;

      pre.parentNode.insertBefore(block, pre);
      cmd.appendChild(pre);

      var btn = document.createElement('button');
      btn.className = 'copy-btn';
      btn.setAttribute('aria-label', 'Copy code');
      btn.innerHTML = '<svg class="copy-icon copy-icon-default" viewBox="0 0 24 24" width="14" height="14"><path d="M9 9a2 2 0 0 1 2-2h7a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-7a2 2 0 0 1-2-2z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M15 7V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h1" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg><svg class="copy-icon copy-icon-check" viewBox="0 0 24 24" width="14" height="14"><path d="M5 12l5 5L20 7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>';
      btn.addEventListener('click', async function() {
        try { await navigator.clipboard.writeText(text); } catch(e) { return; }
        btn.classList.add('is-copied');
        setTimeout(function() { btn.classList.remove('is-copied'); }, 1500);
      });
      cmd.appendChild(btn);
      block.appendChild(cmd);
    });
  </script>
</Landing>
