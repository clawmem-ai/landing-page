---
import Landing from '../../layouts/Landing.astro';
import '../../styles/landing.css';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Landing title="Blog - ClawMem" description="Updates, guides, and insights from the ClawMem team.">
  <style>
    .blog-header { padding: 4rem 0 2.5rem; text-align: center; }
    .blog-header h1 { font-family: var(--font-display); font-size: 2.5rem; color: var(--text-primary); margin-bottom: 0.5rem; }
    .blog-header p { color: var(--text-secondary); }
    .blog-list { list-style: none; display: flex; flex-direction: column; gap: 1.5rem; padding-bottom: 4rem; }
    .blog-card { background: var(--surface-card); border: 1px solid var(--border-subtle); border-radius: var(--radius); padding: 1.5rem; text-decoration: none; color: inherit; display: block; transition: border-color 0.2s; }
    .blog-card:hover { border-color: var(--coral-bright); }
    .blog-card h2 { font-family: var(--font-display); font-size: 1.25rem; color: var(--text-primary); margin-bottom: 0.5rem; }
    .blog-card p { color: var(--text-secondary); font-size: 0.95rem; }
    .blog-card time { color: var(--text-muted); font-size: 0.85rem; }
    .empty { text-align: center; color: var(--text-secondary); padding: 4rem 0; }
  </style>

  <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
    <span class="theme-icon theme-icon-dark">&#9790;</span>
    <span class="theme-icon theme-icon-light">&#9728;</span>
  </button>

  <nav class="nav">
    <div class="container nav-inner">
      <a href="/" class="brand" aria-label="ClawMem home">
        <span class="brand-text">Claw</span><span class="brand-accent">Mem</span>
      </a>
      <div class="nav-right">
        <div class="nav-links">
          <a href="/">Home</a>
          <a href="/blog/">Blog</a>
          <a href="https://console.clawmem.ai/" target="_blank" rel="noreferrer">Console</a>
        </div>
      </div>
    </div>
  </nav>

  <div class="container page-container">
    <main>
      <header class="blog-header">
        <h1>ClawMem Blog</h1>
        <p>Updates, guides, and insights from the ClawMem team.</p>
      </header>
      {posts.length > 0 ? (
        <ul class="blog-list">
          {posts.map((post) => (
            <a class="blog-card" href={`/blog/${post.id}/`}>
              <time datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
            </a>
          ))}
        </ul>
      ) : (
        <div class="empty">
          <p>No blog posts yet. Stay tuned!</p>
        </div>
      )}
    </main>

    <footer class="footer">
      <div class="footer-inner">
        <div class="footer-nav">
          <a href="/">Home</a>
          <span class="footer-separator">&middot;</span>
          <a href="/blog/" data-i18n="nav.blog">Blog</a>
          <span class="footer-separator">&middot;</span>
          <a href="https://console.clawmem.ai/" target="_blank" rel="noreferrer" data-i18n="nav.console">Console</a>
        </div>
        <p class="copyright" data-i18n="footer.tagline">Structured memory for OpenClaw agents.</p>
        <p class="disclaimer" data-i18n="footer.license">Apache-2.0 License</p>
      </div>
    </footer>
  </div>
</Landing>
